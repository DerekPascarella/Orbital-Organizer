<Window x:Class="OrbitalOrganizer.RegionSelectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Console Region" SizeToContent="WidthAndHeight" MinWidth="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,15"
                   Text="In order for Rhea/Phoebe to properly handle out-of-region games, please select your console's region."/>

        <ComboBox x:Name="RegionComboBox" Grid.Row="1" Margin="0,0,0,15"
                  SelectedIndex="0" HorizontalAlignment="Stretch"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Click="OkButton_Click" Width="90" Height="28" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
