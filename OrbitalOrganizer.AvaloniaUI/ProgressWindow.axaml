<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="100"
        x:Class="OrbitalOrganizer.ProgressWindow"
        Title="Progress" Height="100" Width="600" MinHeight="100" MinWidth="600"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Closing="Window_Closing">
  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="20"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <ProgressBar Grid.Row="0" Minimum="0"
                 Maximum="{Binding TotalItems, Mode=OneWay}"
                 Value="{Binding ProcessedItems, Mode=OneWay}"/>
    <Label Grid.Row="1" Content="{Binding TextContent, Mode=OneWay}"/>
  </Grid>
</Window>
