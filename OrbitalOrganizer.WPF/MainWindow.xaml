<Window x:Class="OrbitalOrganizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:OrbitalOrganizer.Converter"
        xmlns:dd="urn:gong-wpf-dragdrop"
        mc:Ignorable="d"
        Title="Orbital Organizer" Height="800" Width="1020" MinHeight="400" MinWidth="1020"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">
    <Window.Resources>
        <ResourceDictionary>
            <conv:BoolToInverseBoolConverter x:Key="BoolToInverseBool"/>
            <conv:BoolToVisibleOrCollapsedConverter x:Key="BoolToVisibleOrCollapsed"/>
            <conv:FolderNumberConverter x:Key="FolderNumber"/>
            <conv:ByteSizeToStringConverter x:Key="ByteSizeToString"/>

            <!--icons from materialdesignicons.com-->
            <Viewbox x:Key="ViewInfo" Width="18" Height="18" x:Shared="False">
                <Canvas Width="24" Height="24">
                    <Path Data="M13.5,4A1.5,1.5 0 0,0 12,5.5A1.5,1.5 0 0,0 13.5,7A1.5,1.5 0 0,0 15,5.5A1.5,1.5 0 0,0 13.5,4M13.14,8.77C11.95,8.87 8.7,11.46 8.7,11.46C8.5,11.61 8.56,11.6 8.72,11.88C8.88,12.15 8.86,12.17 9.05,12.04C9.25,11.91 9.58,11.7 10.13,11.36C12.25,10 10.47,13.14 9.56,18.43C9.2,21.05 11.56,19.7 12.17,19.3C12.77,18.91 14.38,17.8 14.54,17.69C14.76,17.54 14.6,17.42 14.43,17.17C14.31,17 14.19,17.12 14.19,17.12C13.54,17.55 12.35,18.45 12.19,17.88C12,17.31 13.22,13.4 13.89,10.71C14,10.07 14.3,8.67 13.14,8.77Z" Fill="Black" />
                </Canvas>
            </Viewbox>
            <Viewbox x:Key="ViewOpenFolder" x:Shared="False" Width="18" Height="18">
                <Canvas Width="24" Height="24">
                    <Path Data="M19,20H4C2.89,20 2,19.1 2,18V6C2,4.89 2.89,4 4,4H10L12,6H19A2,2 0 0,1 21,8H21L4,8V18L6.14,10H23.21L20.93,18.5C20.7,19.37 19.92,20 19,20Z" Fill="Black" />
                </Canvas>
            </Viewbox>
            <Viewbox x:Key="ViewRefresh" Width="18" Height="18" x:Shared="False">
                <Canvas Width="24" Height="24">
                    <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" Fill="Black" />
                </Canvas>
            </Viewbox>
            <Viewbox x:Key="ViewAdd" Width="24" Height="24">
                <Canvas Width="24" Height="24">
                    <Path Fill="Black" Data="M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M13,7H11V11H7V13H11V17H13V13H17V11H13V7Z" />
                </Canvas>
            </Viewbox>
            <Viewbox x:Key="ViewRemove" Width="24" Height="24">
                <Canvas Width="24" Height="24">
                    <Path Fill="Black" Data="M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M7,13H17V11H7" />
                </Canvas>
            </Viewbox>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ProgressBar Grid.Row="0" Height="5" IsIndeterminate="{Binding IsBusy, Mode=OneWay}"/>

        <GroupBox Grid.Row="1" Header="Settings" Margin="10" IsEnabled="{Binding IsBusy, Mode=OneWay, Converter={StaticResource BoolToInverseBool}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SD Drive -->
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0" VerticalAlignment="Center">SD Drive</Label>
                    <Button Grid.Column="1" Width="30" Margin="10 0 0 0" Click="ButtonBrowseSdPath_Click" ToolTip="Browse for custom SD card folder">
                        <ContentControl Content="{StaticResource ViewOpenFolder}" />
                    </Button>
                    <ComboBox Grid.Column="2" x:Name="DriveComboBox" Width="150" VerticalContentAlignment="Center"
                              SelectionChanged="DriveList_SelectionChanged"
                              Visibility="{Binding IsUsingCustomPath, Converter={StaticResource BoolToVisibleOrCollapsed}, ConverterParameter=Inverse}"/>
                    <TextBox Grid.Column="2" Width="150" VerticalContentAlignment="Center" Text="{Binding CustomSdPath, Mode=OneWay}" IsReadOnly="True"
                             Visibility="{Binding IsUsingCustomPath, Converter={StaticResource BoolToVisibleOrCollapsed}}"/>
                    <Button Grid.Column="3" Width="30" ToolTip="Refresh drive list and clear custom path" Click="ButtonRefreshDrives_Click">
                        <ContentControl Content="{StaticResource ViewRefresh}" />
                    </Button>
                </Grid>

                <!-- Temp. Folder -->
                <Grid Grid.Column="1" Margin="30 0 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" VerticalAlignment="Center">Temp. Folder</Label>
                    <Button Grid.Column="1" Width="30" Margin="10 0 0 0" Click="ButtonBrowseTempFolder_Click"
                            ToolTip="Browse for custom temporary folder">
                        <ContentControl Content="{StaticResource ViewOpenFolder}" />
                    </Button>
                    <TextBox Grid.Column="2" x:Name="TempFolderTextBox" Width="150" IsReadOnly="True"
                             VerticalContentAlignment="Center"/>
                    <Button Grid.Column="3" Width="30" Click="ButtonResetTempFolder_Click"
                            ToolTip="Reset to system default">
                        <ContentControl Content="{StaticResource ViewRefresh}" />
                    </Button>
                </Grid>

                <!-- Menu Type (horizontal) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="30 0 0 0" VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center" Margin="0 1 0 0">Menu Type</TextBlock>
                    <RadioButton x:Name="RadioRmenuKai" Content="RmenuKai" GroupName="MenuType" VerticalAlignment="Center" Margin="10 0 0 0" ToolTip="Use RmenuKai"
                                 Padding="4 0 0 0" IsChecked="True" Checked="MenuType_Changed"/>
                    <RadioButton x:Name="RadioRmenu" Content="RMENU" GroupName="MenuType" VerticalAlignment="Center" Margin="10 0 0 0" ToolTip="Use RMENU"
                                 Padding="4 0 0 0" Checked="MenuType_Changed"/>
                    <RadioButton x:Name="RadioBoth" Content="Both" GroupName="MenuType" VerticalAlignment="Center" Margin="10 0 0 0" ToolTip="Use Both"
                                 Padding="4 0 0 0" Checked="MenuType_Changed"/>
                </StackPanel>

                <!-- About button (right-aligned) -->
                <Button Grid.Column="3" Width="30" Margin="30 0 0 0" HorizontalAlignment="Right" ToolTip="About" Click="ButtonAbout_Click">
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                            <Path Data="M11,9H13V7H11M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M11,17H13V11H11V17Z" Fill="Black" />
                        </Canvas>
                    </Viewbox>
                </Button>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="2" Margin="10 0 10 10" IsEnabled="{Binding IsBusy, Mode=OneWay, Converter={StaticResource BoolToInverseBool}}">
            <GroupBox.Header>
                <TextBlock>
                    Games List [<Run Text="{Binding GamesListHeader, Mode=OneWay}"/>]
                </TextBlock>
            </GroupBox.Header>
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Button x:Name="ButtonBatchFolderRename" DockPanel.Dock="Right" HorizontalAlignment="Right" Padding="10 5" Margin="10 0 0 0" Click="ButtonBatchFolderRename_Click"
                            ToolTip="Easily rearrange and rename virtual folders"
                            IsEnabled="{Binding HasSdPath, Mode=OneWay}">Batch Folder Move and Rename</Button>
                    <Button x:Name="ButtonSort" DockPanel.Dock="Right" HorizontalAlignment="Right" Padding="10 5" Click="ButtonSort_Click" ToolTip="Sort list by folder path + title"
                            IsEnabled="{Binding HasSdPath, Mode=OneWay}">Sort List</Button>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center">Search/Filter</TextBlock>
                        <TextBox x:Name="FilterTextBox" Width="200" MaxLength="256" Margin="10 0 0 0"
                                 VerticalContentAlignment="Center"
                                 IsEnabled="{Binding HasSdPath, Mode=OneWay}"/>
                        <Button Padding="10 5" Margin="10 0 0 0" Click="ButtonSearch_Click"
                                ToolTip="Search by title or serial (navigate to next match)"
                                IsDefault="{Binding Path=IsFocused, ElementName=FilterTextBox, Mode=OneWay}"
                                IsEnabled="{Binding HasSdPath, Mode=OneWay}">
                            <Viewbox Width="16" Height="16">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="Black" Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button Padding="10 5" Margin="5 0 0 0" Click="ButtonFilter_Click"
                                ToolTip="Filter by title or serial"
                                IsEnabled="{Binding HasSdPath, Mode=OneWay}">
                            <Viewbox Width="16" Height="16">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="Black" Data="M3,2H21L14,12V22L10,20V12L3,2Z"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button Padding="10 5" Margin="5 0 0 0" Click="ButtonFilterReset_Click"
                                ToolTip="Clear filter and show all items"
                                IsEnabled="{Binding IsFilterActive, Mode=OneWay}">
                            <Viewbox Width="16" Height="16">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="Black" Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </DockPanel>

                <DataGrid x:Name="GameGrid" AutoGenerateColumns="False" CanUserResizeRows="False"
                          CanUserSortColumns="False" CanUserReorderColumns="False" CanUserAddRows="False"
                          SelectionMode="Extended" IsReadOnly="False"
                          BeginningEdit="GameGrid_BeginningEdit" CellEditEnding="GameGrid_CellEditEnding"
                          PreviewKeyDown="GameGrid_PreviewKeyDown"
                          dd:DragDrop.DropHandler="{Binding Path=., Mode=OneWay}"
                          dd:DragDrop.IsDragSource="{Binding IsBusy, Mode=OneWay, Converter={StaticResource BoolToInverseBool}}"
                          dd:DragDrop.IsDropTarget="{Binding IsBusy, Mode=OneWay, Converter={StaticResource BoolToInverseBool}}"
                          Margin="0,0,0,8">
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Resources>
                        <ContextMenu x:Key="rowmenu" Opened="ContextMenu_Opened">
                            <MenuItem x:Name="MenuItemRename" Header="Rename" Click="MenuItemRename_Click"/>
                            <MenuItem Header="Title Case" Click="MenuItemTitleCase_Click"/>
                            <MenuItem Header="Uppercase" Click="MenuItemUppercase_Click"/>
                            <MenuItem Header="Lowercase" Click="MenuItemLowercase_Click"/>
                            <MenuItem x:Name="MenuItemAutoRename" Header="Automatically Rename Title">
                                <MenuItem Header="Using IP.BIN info" Click="MenuItemRenameIP_Click"/>
                                <MenuItem x:Name="MenuItemRenameFolder" Header="Using its folder name on computer" Click="MenuItemRenameFolder_Click"/>
                                <MenuItem x:Name="MenuItemRenameFile" Header="Using disc image's base file name" Click="MenuItemRenameFile_Click"/>
                            </MenuItem>
                            <Separator x:Name="AssignFolderSeparator"/>
                            <MenuItem x:Name="MenuItemAssignFolder" Header="Assign Folder Path" Click="MenuItemAssignFolder_Click"/>
                            <MenuItem x:Name="MenuItemAssignAltFolders" Header="Assign Additional Folder Paths" Click="MenuItemAssignAltFolders_Click"/>
                        </ContextMenu>
                    </DataGrid.Resources>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Setter Property="ContextMenu" Value="{StaticResource rowmenu}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMenuItem}" Value="True">
                                    <Setter Property="ContextMenu" Value="{x:Null}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Click="ButtonInfo_Click" ToolTip="View Disc Image Info" CommandParameter="{Binding Path=., Mode=OneWay}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMenuItem}" Value="True">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsLegacyRmenu}" Value="True">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <ContentControl Content="{StaticResource ViewInfo}" />
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Location" Width="65" IsReadOnly="True" Binding="{Binding Location, Mode=OneWay}"/>
                        <DataGridTextColumn Width="50" IsReadOnly="True" Binding="{Binding FolderNumberFormatted, Mode=OneWay}">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="SD #" ToolTip="Current item folder on SD card"/>
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Size" Width="72" IsReadOnly="True" Binding="{Binding Length, Mode=OneWay, Converter={StaticResource ByteSizeToString}}"/>
                        <DataGridTextColumn Header="Title" Width="2*" Binding="{Binding Name, Mode=TwoWay}"/>
                        <DataGridTemplateColumn Header="Folder" Width="1*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Folder}" VerticalAlignment="Center" Margin="2,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox IsEditable="True"
                                              Text="{Binding Folder, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                              ItemsSource="{Binding DataContext.KnownFolders, RelativeSource={RelativeSource AncestorType=Window}}"
                                              GotFocus="FolderComboBox_GotFocus"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Product ID" Width="85" Binding="{Binding ProductId, Mode=TwoWay}"/>
                        <DataGridTextColumn Header="Disc" Width="50" Binding="{Binding Disc, Mode=TwoWay}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </GroupBox>

        <Grid Grid.Row="3" Margin="5 0 5 10" IsEnabled="{Binding IsBusy, Mode=OneWay, Converter={StaticResource BoolToInverseBool}}">
            <Grid IsEnabled="{Binding HasSdPath, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Width="50" Margin="10 0" ToolTip="Add game(s)" Click="ButtonAdd_Click" Content="{StaticResource ViewAdd}"/>
                <Button Grid.Column="1" Width="50" Margin="0 0 10 0" ToolTip="Remove selected game(s)" Click="ButtonRemove_Click" Content="{StaticResource ViewRemove}"/>

                <Button Grid.Column="2" Width="50" Margin="10 0" ToolTip="Move selected game(s) up" Click="ButtonMoveUp_Click">
                    <Viewbox Width="24" Height="24">
                        <Canvas Width="24" Height="24">
                            <Path Fill="Black" Data="M12,7L17,12H14V16H10V12H7L12,7M12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20Z" />
                        </Canvas>
                    </Viewbox>
                </Button>
                <Button Grid.Column="3" Width="50" Margin="0 0 10 0" ToolTip="Move selected game(s) down" Click="ButtonMoveDown_Click">
                    <Viewbox Width="24" Height="24">
                        <Canvas Width="24" Height="24">
                            <Path Fill="Black" Data="M12,17L7,12H10V8H14V12H17L12,17M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4Z" />
                        </Canvas>
                    </Viewbox>
                </Button>

                <CheckBox Grid.Column="4" x:Name="LockCheckBox" VerticalAlignment="Center" Margin="10 0"
                          IsChecked="True" ToolTip="Check for locked files/folders before saving">File/Folder Lock Check</CheckBox>

                <Button Grid.Column="5" Margin="10 0" Padding="0 10" FontWeight="Bold"
                        Click="ButtonSave_Click" ToolTip="Save changes to SD card">Save Changes</Button>

                <Button Grid.Column="6" Margin="0 0 5 0" Padding="10 10" Click="ButtonUndo_Click"
                        ToolTip="Undo last change"
                        IsEnabled="{Binding UndoManager.CanUndo, Mode=OneWay}">Undo</Button>
                <Button Grid.Column="7" Margin="5 0 10 0" Padding="10 10" Click="ButtonRedo_Click"
                        ToolTip="Redo last change"
                        IsEnabled="{Binding UndoManager.CanRedo, Mode=OneWay}">Redo</Button>
            </Grid>
        </Grid>

    </Grid>
</Window>
