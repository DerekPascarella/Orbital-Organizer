<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OrbitalOrganizer"
        mc:Ignorable="d" d:DesignWidth="1035" d:DesignHeight="650"
        x:Class="OrbitalOrganizer.MainWindow"
        Title="Orbital Organizer" Width="1035" Height="800" MinWidth="1035" MinHeight="400"
        Icon="/Assets/saturn_logo.ico"
        WindowStartupLocation="CenterScreen"
        DragDrop.AllowDrop="{Binding Path=!IsBusy, Mode=OneWay}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ProgressBar Grid.Row="0" Height="5" IsIndeterminate="{Binding IsBusy, Mode=OneWay}"/>

        <HeaderedContentControl Grid.Row="1" Header="Settings" Margin="10" IsEnabled="{Binding !IsBusy, Mode=OneWay}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SD Drive -->
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" VerticalAlignment="Center">SD Drive</TextBlock>
                    <Button Grid.Column="1" Width="30" Margin="10,0,0,0" Click="ButtonBrowseSdPath_Click"
                            ToolTip.Tip="Browse for custom SD card folder">
                        <Viewbox Width="18" Height="18">
                            <Canvas Width="24" Height="24">
                                <Path Data="M19,20H4C2.89,20 2,19.1 2,18V6C2,4.89 2.89,4 4,4H10L12,6H19A2,2 0 0,1 21,8H21L4,8V18L6.14,10H23.21L20.93,18.5C20.7,19.37 19.92,20 19,20Z"
                                      Fill="Black" />
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <ComboBox Grid.Column="2" x:Name="DriveComboBox" Width="150"
                              SelectionChanged="DriveList_SelectionChanged"
                              IsVisible="{Binding !IsUsingCustomPath, Mode=OneWay}"/>
                    <TextBox Grid.Column="2" Width="150" VerticalContentAlignment="Center"
                             Text="{Binding CustomSdPath, Mode=OneWay}" IsReadOnly="True"
                             IsVisible="{Binding IsUsingCustomPath, Mode=OneWay}"/>
                    <Button Grid.Column="3" Width="30"
                            ToolTip.Tip="Refresh drive list and clear custom path"
                            Click="ButtonRefreshDrives_Click">
                        <Viewbox Width="18" Height="18">
                            <Canvas Width="24" Height="24">
                                <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                                      Fill="Black" />
                            </Canvas>
                        </Viewbox>
                    </Button>
                </Grid>

                <!-- Temp. Folder -->
                <Grid Grid.Column="1" Margin="30,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center">Temp. Folder</TextBlock>
                    <Button Grid.Column="1" Width="30" Margin="10,0,0,0" Click="ButtonBrowseTempFolder_Click"
                            ToolTip.Tip="Browse for custom temporary folder">
                        <Viewbox Width="18" Height="18">
                            <Canvas Width="24" Height="24">
                                <Path Data="M19,20H4C2.89,20 2,19.1 2,18V6C2,4.89 2.89,4 4,4H10L12,6H19A2,2 0 0,1 21,8H21L4,8V18L6.14,10H23.21L20.93,18.5C20.7,19.37 19.92,20 19,20Z"
                                      Fill="Black" />
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <TextBox Grid.Column="2" x:Name="TempFolderTextBox" Width="150" IsReadOnly="True"
                             VerticalContentAlignment="Center"/>
                    <Button Grid.Column="3" Width="30" Click="ButtonResetTempFolder_Click"
                            ToolTip.Tip="Reset to system default">
                        <Viewbox Width="18" Height="18">
                            <Canvas Width="24" Height="24">
                                <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                                      Fill="Black" />
                            </Canvas>
                        </Viewbox>
                    </Button>
                </Grid>

                <!-- Menu Type -->
                <Grid Grid.Column="2" Margin="30,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center">Menu Type</TextBlock>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                        <RadioButton x:Name="RadioRmenuKai" Content="RmenuKai" GroupName="MenuType"
                                     IsChecked="True" Checked="MenuType_Changed" ToolTip.Tip="Use RmenuKai"/>
                        <RadioButton x:Name="RadioRmenu" Content="RMENU" GroupName="MenuType" Margin="10,0,0,0"
                                     Checked="MenuType_Changed" ToolTip.Tip="Use RMENU"/>
                        <RadioButton x:Name="RadioBoth" Content="Both" GroupName="MenuType" Margin="10,0,0,0"
                                     Checked="MenuType_Changed" ToolTip.Tip="Use Both"/>
                    </StackPanel>
                </Grid>

                <!-- About button -->
                <Button Grid.Column="3" Width="30" Margin="30,0,0,0" HorizontalAlignment="Right"
                        ToolTip.Tip="About" Click="ButtonAbout_Click">
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                            <Path Data="M11,9H13V7H11M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M11,17H13V11H11V17Z"
                                  Fill="Black" />
                        </Canvas>
                    </Viewbox>
                </Button>
            </Grid>
        </HeaderedContentControl>

        <HeaderedContentControl Grid.Row="2" Margin="10,0,10,10" IsEnabled="{Binding !IsBusy, Mode=OneWay}">
            <HeaderedContentControl.Header>
                <TextBlock>
                    <Run Text="Games List ["/><Run Text="{Binding GamesListHeader, Mode=OneWay}"/><Run Text="]"/>
                </TextBlock>
            </HeaderedContentControl.Header>
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Button x:Name="ButtonSort" DockPanel.Dock="Right" HorizontalAlignment="Right" Padding="10,5" Click="ButtonSort_Click"
                            ToolTip.Tip="Sort list by folder path + title"
                            IsEnabled="{Binding CanModifyList, Mode=OneWay}">Sort List</Button>

                    <Grid HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label VerticalAlignment="Center">Search/Filter</Label>
                        <TextBox Grid.Column="1" x:Name="FilterTextBox" Width="200" MaxLength="256" Margin="10,0,0,0"
                                 VerticalContentAlignment="Center"
                                 IsEnabled="{Binding HasSdPath, Mode=OneWay}"/>
                        <Button Grid.Column="2" Width="30" Margin="10,0,0,0" Click="ButtonSearch_Click"
                                ToolTip.Tip="Search by title or serial (navigate to next match)"
                                IsDefault="{Binding #FilterTextBox.IsFocused, Mode=OneWay}"
                                IsEnabled="{Binding HasSdPath, Mode=OneWay}">
                            <Viewbox Width="20" Height="20">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="Black" Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button Grid.Column="3" Width="30" Margin="5,0,0,0" Click="ButtonFilter_Click"
                                ToolTip.Tip="Filter by title or serial"
                                IsEnabled="{Binding HasSdPath, Mode=OneWay}">
                            <Viewbox Width="20" Height="20">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="Black" Data="M14,12V19.88C14.04,20.18 13.94,20.5 13.71,20.71C13.32,21.1 12.69,21.1 12.3,20.71L10.29,18.7C10.06,18.47 9.96,18.16 10,17.87V12L4.21,4.62C3.87,4.19 3.95,3.56 4.38,3.22C4.57,3.08 4.78,3 5,3H19C19.22,3 19.43,3.08 19.62,3.22C20.05,3.56 20.13,4.19 19.79,4.62L14,12Z"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button Grid.Column="4" Width="30" Margin="5,0,0,0" Click="ButtonFilterReset_Click"
                                ToolTip.Tip="Clear filter and show all items"
                                IsEnabled="{Binding IsFilterActive, Mode=OneWay}">
                            <Viewbox Width="18" Height="18">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="Black" Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </Grid>
                </DockPanel>

                <DataGrid x:Name="GameGrid"
                          AutoGenerateColumns="False"
                          CanUserSortColumns="False"
                          CanUserReorderColumns="False"
                          CanUserResizeColumns="False"
                          SelectionMode="Extended"
                          IsReadOnly="False"
                          RowBackground="White"
                          GridLinesVisibility="All"
                          BorderBrush="Black" BorderThickness="1"
                          HorizontalGridLinesBrush="LightGray"
                          VerticalGridLinesBrush="LightGray"
                          BeginningEdit="GameGrid_BeginningEdit"
                          CellEditEnding="GameGrid_CellEditEnding">
                    <DataGrid.Styles>
                        <Style Selector="DataGridRow">
                            <Setter Property="ContextMenu" Value="{DynamicResource rowmenu}"/>
                        </Style>
                    </DataGrid.Styles>
                    <DataGrid.Resources>
                        <ContextMenu x:Key="rowmenu" Opening="ContextMenu_Opening">
                            <MenuItem x:Name="MenuItemRename" Header="Rename" Click="MenuItemRename_Click"/>
                            <MenuItem Header="Title Case" Click="MenuItemTitleCase_Click"/>
                            <MenuItem Header="Uppercase" Click="MenuItemUppercase_Click"/>
                            <MenuItem Header="Lowercase" Click="MenuItemLowercase_Click"/>
                            <MenuItem x:Name="MenuItemAutoRename" Header="Automatically Rename Title">
                                <MenuItem Header="Using IP.BIN info" Click="MenuItemRenameIP_Click"/>
                                <MenuItem x:Name="MenuItemRenameFolder" Header="Using its folder name on computer" Click="MenuItemRenameFolder_Click"/>
                                <MenuItem x:Name="MenuItemRenameFile" Header="Using disc image's base file name" Click="MenuItemRenameFile_Click"/>
                            </MenuItem>
                            <Separator x:Name="AssignFolderSeparator"/>
                            <MenuItem x:Name="MenuItemAssignFolder" Header="Assign Folder Path" Click="MenuItemAssignFolder_Click"/>
                            <MenuItem x:Name="MenuItemAssignAltFolders" Header="Assign Additional Folder Paths" Click="MenuItemAssignAltFolders_Click"/>
                        </ContextMenu>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Click="ButtonInfo_Click" ToolTip.Tip="View Disc Image Info" CommandParameter="{Binding}" IsEnabled="{Binding IsGameEntry, Mode=OneWay}">
                                        <Viewbox Width="18" Height="18">
                                            <Canvas Width="24" Height="24">
                                                <Path Data="M13.5,4A1.5,1.5 0 0,0 12,5.5A1.5,1.5 0 0,0 13.5,7A1.5,1.5 0 0,0 15,5.5A1.5,1.5 0 0,0 13.5,4M13.14,8.77C11.95,8.87 8.7,11.46 8.7,11.46C8.5,11.61 8.56,11.6 8.72,11.88C8.88,12.15 8.86,12.17 9.05,12.04C9.25,11.91 9.58,11.7 10.13,11.36C12.25,10 10.47,13.14 9.56,18.43C9.2,21.05 11.56,19.7 12.17,19.3C12.77,18.91 14.38,17.8 14.54,17.69C14.76,17.54 14.6,17.42 14.43,17.17C14.31,17 14.19,17.12 14.19,17.12C13.54,17.55 12.35,18.45 12.19,17.88C12,17.31 13.22,13.4 13.89,10.71C14,10.07 14.3,8.67 13.14,8.77Z" Fill="Black" />
                                            </Canvas>
                                        </Viewbox>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Location" Binding="{Binding Location, Mode=OneWay}" Width="65" IsReadOnly="True"/>
                        <DataGridTextColumn Binding="{Binding FolderNumberFormatted, Mode=OneWay}" Width="50" IsReadOnly="True">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="SD #" ToolTip.Tip="Current item folder on SD card"/>
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Size" Binding="{Binding Length, Mode=OneWay, Converter={x:Static local:Converters.ByteSizeConverter}}" Width="72" IsReadOnly="True"/>
                        <DataGridTemplateColumn Header="Title" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name, Mode=OneWay}" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Name, Mode=TwoWay}" Foreground="Black"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Folder" Width="1*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Folder, Mode=OneWay}" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Folder, Mode=TwoWay}" Foreground="Black"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Product ID" Width="85">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ProductId, Mode=OneWay}" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding ProductId, Mode=TwoWay}" Foreground="Black"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Disc" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Disc, Mode=OneWay}" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Disc, Mode=TwoWay}" Foreground="Black"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </HeaderedContentControl>

        <Grid Grid.Row="3" Margin="5,0,5,10" IsEnabled="{Binding !IsBusy, Mode=OneWay}">
            <Grid IsEnabled="{Binding HasSdPath, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Width="50" Margin="10,0" ToolTip.Tip="Add game(s)" Click="ButtonAdd_Click"
                        IsEnabled="{Binding !IsFilterActive, Mode=OneWay}">
                    <Viewbox Width="24" Height="24">
                        <Canvas Width="24" Height="24">
                            <Path Fill="Black"
                                  Data="M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M13,7H11V11H7V13H11V17H13V13H17V11H13V7Z" />
                        </Canvas>
                    </Viewbox>
                </Button>
                <Button Grid.Column="1" Width="50" Margin="0,0,10,0" ToolTip.Tip="Remove selected game(s)" Click="ButtonRemove_Click">
                    <Viewbox Width="24" Height="24">
                        <Canvas Width="24" Height="24">
                            <Path Fill="Black"
                                  Data="M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M7,13H17V11H7" />
                        </Canvas>
                    </Viewbox>
                </Button>

                <Button Grid.Column="2" Width="50" Margin="10,0" ToolTip.Tip="Move selected game(s) up" Click="ButtonMoveUp_Click"
                        IsEnabled="{Binding !IsFilterActive, Mode=OneWay}">
                    <Viewbox Width="24" Height="24">
                        <Canvas Width="24" Height="24">
                            <Path Fill="Black"
                                  Data="M12,7L17,12H14V16H10V12H7L12,7M12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20Z" />
                        </Canvas>
                    </Viewbox>
                </Button>
                <Button Grid.Column="3" Width="50" Margin="0,0,10,0" ToolTip.Tip="Move selected game(s) down" Click="ButtonMoveDown_Click"
                        IsEnabled="{Binding !IsFilterActive, Mode=OneWay}">
                    <Viewbox Width="24" Height="24">
                        <Canvas Width="24" Height="24">
                            <Path Fill="Black"
                                  Data="M12,17L7,12H10V8H14V12H17L12,17M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4Z" />
                        </Canvas>
                    </Viewbox>
                </Button>

                <CheckBox Grid.Column="4" x:Name="LockCheckBox" VerticalAlignment="Center" Margin="10,0"
                          IsChecked="True" ToolTip.Tip="Check for locked files/folders before saving">File/Folder Lock Check</CheckBox>

                <Button Grid.Column="5" Margin="10,0" Padding="0,10" FontWeight="Bold"
                        Click="ButtonSave_Click" ToolTip.Tip="Save changes to SD card"
                        IsEnabled="{Binding !IsFilterActive, Mode=OneWay}">Save Changes</Button>

                <Button Grid.Column="6" Margin="0,0,5,0" Padding="10,10" Click="ButtonUndo_Click"
                        ToolTip.Tip="Undo last change"
                        IsEnabled="{Binding UndoManager.CanUndo, Mode=OneWay}">Undo</Button>
                <Button Grid.Column="7" Margin="5,0,10,0" Padding="10,10" Click="ButtonRedo_Click"
                        ToolTip.Tip="Redo last change"
                        IsEnabled="{Binding UndoManager.CanRedo, Mode=OneWay}">Redo</Button>
            </Grid>
        </Grid>
    </Grid>
</Window>
