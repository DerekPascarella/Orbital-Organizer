<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="200"
        x:Class="OrbitalOrganizer.AboutWindow"
        Title="About" SizeToContent="WidthAndHeight" CanResize="False"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="15,8">
        <TextBlock FontWeight="Bold" FontSize="16">
            <Run Text="Orbital Organizer"/>
            <Run x:Name="VersionRun"/>
        </TextBlock>
        <TextBlock Margin="0,4,0,0">by Derek Pascarella (ateam)</TextBlock>
        <TextBlock Margin="0,10,0,0" TextWrapping="Wrap">An SD card management tool for the SEGA Saturn ODEs Rhea and Phoebe.</TextBlock>
        <TextBlock Margin="0,10,0,0">Documentation:</TextBlock>
        <TextBlock Margin="0,2,0,0" Foreground="Blue" TextDecorations="Underline"
                   Cursor="Hand" PointerPressed="LinkText_PointerPressed">https://github.com/DerekPascarella/OrbitalOrganizer</TextBlock>
        <Button Content="Check for Updates" Click="CheckForUpdatesButton_Click"
                Margin="0,15,0,0" HorizontalAlignment="Right"
                Padding="12,0" Height="28"
                VerticalContentAlignment="Center"/>
    </StackPanel>
</Window>
